{
  "name": "pomodoro-timer",
  "version": "1.0.0",
  "description": "A Pomodoro timer desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.pomodoro.timer",
    "productName": "Pomodoro Timer",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "assets/**"
    ]
  }
}
