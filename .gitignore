# 依赖包 (绝对不能上传)
node_modules/

# npm/yarn 的错误日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Electron 打包输出的文件夹 (不要把几十上百兆的成品软件传到代码库里)
dist/
dist-zip/
out/
build/
release/

# 环境变量文件 (保护你的 API 密钥等敏感信息)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 操作系统自动生成的隐藏文件
.DS_Store
Thumbs.db